---
import Layout from '../layouts/Layout.astro';
import { sutras } from '../data/sutras';
import { formatSutraId } from '../utils/formatSutraId';

const sutraList = Object.values(sutras);
const paniniCount = sutraList.filter(s => s.source === 'panini').length;
const katantraCount = sutraList.filter(s => s.source === 'katantra').length;
const jkvCount = sutraList.filter(s => s.source === 'jkv').length;
const dsskCount = sutraList.filter(s => s.source === 'dssk').length;
const totalCount = sutraList.length;

// 按时间戳排序（最新在前），如果没有时间戳则使用默认顺序
const recentSutras = sutraList
  .sort((a, b) => {
    if (a.updatedAt && b.updatedAt) {
      return b.updatedAt - a.updatedAt; // 最新的在前
    }
    return 0; // 保持原顺序
  })
  .slice(0, 6);
---

<Layout title="首页">
  <div class="hero">
    <h1>Vyākaraṇa Atlas</h1>
    <p>
      个人梵语语法笔记，用可视化图谱方式展示梵语语法经文之间的关系网络。
    </p>
    <p style="color: #64748b; font-size: 0.875rem;">
      当前收录: Pāṇini {paniniCount} 条 | Kātantra {katantraCount} 条 | Kāśikāvṛṭti {jkvCount} 条 | 段晴《波你尼语法入门》{dsskCount} 条 | 共 {totalCount} 条
    </p>
    <a href="/Sanskrit/atlas" class="view-link" style="font-size: 1.25rem;">
      进入图谱视图 →
    </a>
  </div>

  <h2 style="margin-bottom: 1rem;">最近添加</h2>
  <div class="sutra-list">
    {recentSutras.map(sutra => (
      <a href={`/Sanskrit/sutra/${sutra.id}`} class="sutra-card">
        <h3>{formatSutraId(sutra.id)}</h3>
        <p>{sutra.text}</p>
      </a>
    ))}
  </div>

  <hr style="margin: 3rem 0; border: none; border-top: 1px solid var(--color-border);" />

  <div style="color: #64748b; font-size: 0.875rem; line-height: 1.8;">
    <p><strong>About</strong></p>
    <p>
      本项目由
      <a href="https://github.com/zhangxueshan246" style="color: var(--color-panini); text-decoration: none;">zhangxueshan246</a>
      与 Claude AI 共同开发。
    </p>
  </div>
</Layout>
