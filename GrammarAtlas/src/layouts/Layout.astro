---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Grammar Atlas' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Grammar Atlas</title>
  <link rel="icon" type="image/svg+xml" href="/Sanskrit/favicon.svg" />
</head>
<body>
  <div class="layout">
    <header>
      <h1><a href="/Sanskrit/">Grammar Atlas</a></h1>
      <nav>
        <a href="/Sanskrit/">首页</a>
        <a href="/Sanskrit/atlas">图谱</a>
        <a href="/Sanskrit/sutras">经文列表</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </div>
</body>
</html>
